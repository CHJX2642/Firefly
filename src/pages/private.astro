---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { removeFileExtension } from "@/utils/url-utils";

// 获取所有文章（包括私密文章，因为这是私密页面）
const allPosts = await getCollection("posts", ({ data }) => {
  // 在私密页面，只显示私密文章
  return data.private === true;
});

// 获取文章数据
const postsData = allPosts.map(post => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description || "",
  published: post.data.published.toISOString(),
  category: post.data.category || "",
  url: '/private/' + removeFileExtension(post.id) + '/'
}));

const title = "私密文章";
const description = "需要密码访问的私密文章列表";
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题 -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
          <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="text-[1.5rem]" viewBox="0 0 24 24">
              <path fill="currentColor" d="M12 17q.425 0 .713-.288T13 16v-2q0-.425-.288-.712T12 13q-.425 0-.712.288T11 14v2q0 .425.288.713T12 17Zm0-4q.425 0 .713-.288T13 12V9q0-.425-.288-.712T12 8q-.425 0-.712.288T11 9v3q0 .425.288.713T12 13Zm0-9q-2.075 0-3.537 1.463T7 8.5q0 1.25.688 2.325T9.5 12.5h5q1.25 0 1.813-1.075T17 8.5q0-2.075-1.463-3.5T12 4Z"/>
            </svg>
          </div>
          <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            {title}
          </div>
        </div>
        <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
          {description}
        </p>
      </div>

      <!-- 密码验证区域 -->
      <div id="password-section" class="mb-8">
        <div class="flex flex-col items-center justify-center p-8 rounded-lg bg-neutral-50 dark:bg-neutral-900/50 border border-neutral-200 dark:border-neutral-800">
          <div class="mb-4 text-neutral-600 dark:text-neutral-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-2" viewBox="0 0 24 24">
              <path fill="currentColor" d="M12 17q.425 0 .713-.288T13 16v-2q0-.425-.288-.712T12 13q-.425 0-.712.288T11 14v2q0 .425.288.713T12 17Zm0-4q.425 0 .713-.288T13 12V9q0-.425-.288-.712T12 8q-.425 0-.712.288T11 9v3q0 .425.288.713T12 13Zm0-9q-2.075 0-3.537 1.463T7 8.5q0 1.25.688 2.325T9.5 12.5h5q1.25 0 1.813-1.075T17 8.5q0-2.075-1.463-3.5T12 4Z"/>
            </svg>
            <p class="text-lg font-medium">此页面需要密码访问</p>
            <p class="text-sm text-neutral-500 dark:text-neutral-500 mt-1">请输入密码查看私密文章</p>
          </div>
          <form id="password-form" class="flex gap-2 w-full max-w-md">
            <input
              type="password"
              id="password-input"
              placeholder="请输入访问密码"
              autocomplete="current-password"
              class="flex-1 px-4 py-2 rounded-lg border border-neutral-300 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-(--primary)"
            />
            <button
              type="submit"
              class="px-6 py-2 bg-(--primary) text-white dark:text-black/70 rounded-lg font-medium hover:bg-(--primary)/90 active:scale-95 transition-all"
            >
              验证
            </button>
          </form>
          <p id="error-msg" class="mt-2 text-red-500 text-sm hidden">密码错误，请重试</p>
        </div>
      </div>

      <!-- 文章列表（默认隐藏） -->
      <div id="posts-section" class="hidden">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <div class="h-8 w-8 rounded-lg bg-(--primary)/10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="text-[1.25rem] text-(--primary)" viewBox="0 0 24 24">
                <path fill="currentColor" d="M4 19q-.425 0-.712-.288T3 18V6q0-.425.288-.712T4 5h16q.425 0 .712.288T21 6v12q0 .425-.288.712T20 19H4Zm0-2h16V6H4v11Z"/>
              </svg>
            </div>
            <h2 class="text-xl font-bold text-neutral-900 dark:text-neutral-100">
              私密文章列表
            </h2>
          </div>
          <span id="post-count" class="text-sm text-neutral-500 dark:text-neutral-500"></span>
        </div>

        <div id="posts-list" class="flex flex-col gap-4">
          <!-- 文章将通过 JavaScript 动态加载 -->
        </div>
      </div>
    </div>
  </div>
</MainGridLayout>

<!-- 隐藏的数据容器 -->
<div id="posts-data" style="display: none;">{JSON.stringify(postsData)}</div>

<script>
  // 私密文章密码
  const PRIVATE_PASSWORD = '582642';

  // 等待 DOM 加载完成
  document.addEventListener('DOMContentLoaded', () => {
    // 获取元素
    const postsDataEl = document.getElementById('posts-data');
    const passwordForm = document.getElementById('password-form') as HTMLFormElement;
    const passwordInput = document.getElementById('password-input') as HTMLInputElement;
    const errorMsg = document.getElementById('error-msg') as HTMLElement;
    const passwordSection = document.getElementById('password-section') as HTMLElement;
    const postsSection = document.getElementById('posts-section') as HTMLElement;
    const postsList = document.getElementById('posts-list') as HTMLElement;
    const postCount = document.getElementById('post-count') as HTMLElement;

    // 解析文章数据
    let allPosts: any[] = [];
    try {
      allPosts = postsDataEl ? JSON.parse(postsDataEl.textContent || '[]') : [];
    } catch (e) {
      console.error('解析文章数据失败:', e);
    }

    console.log('所有文章:', allPosts);

    // 检查是否已经验证过
    const isVerified = sessionStorage.getItem('private_verified') === 'true';
    if (isVerified) {
      showPosts();
    }

    // 表单提交事件
    passwordForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      verifyPassword();
    });

    function verifyPassword() {
      const password = passwordInput?.value?.trim();
      if (password === PRIVATE_PASSWORD) {
        sessionStorage.setItem('private_verified', 'true');
        showPosts();
      } else {
        errorMsg?.classList.remove('hidden');
        passwordInput.value = '';
        passwordInput.focus();
      }
    }

    function showPosts() {
      passwordSection?.classList.add('hidden');
      postsSection?.classList.remove('hidden');
      renderPosts();
    }

    function renderPosts() {
      if (!postsList) return;

      // 更新文章数量
      if (postCount) {
        postCount.textContent = `共 ${allPosts.length} 篇`;
      }

      if (allPosts.length === 0) {
        postsList.innerHTML = `
          <div class="text-center py-12 text-neutral-500 dark:text-neutral-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto mb-4 text-neutral-300 dark:text-neutral-600" viewBox="0 0 24 24">
              <path fill="currentColor" d="M12 17q.425 0 .713-.288T13 16v-2q0-.425-.288-.712T12 13q-.425 0-.712.288T11 14v2q0 .425.288.713T12 17Zm0-4q.425 0 .713-.288T13 12V9q0-.425-.288-.712T12 8q-.425 0-.712.288T11 9v3q0 .425.288.713T12 13Zm0-9q-2.075 0-3.537 1.463T7 8.5q0 1.25.688 2.325T9.5 12.5h5q1.25 0 1.813-1.075T17 8.5q0-2.075-1.463-3.5T12 4Z"/>
            </svg>
            <p class="text-lg">暂无私密文章</p>
            <p class="text-sm mt-1">将文章标记为 private: true 即可在此显示</p>
          </div>
        `;
        return;
      }

      postsList.innerHTML = allPosts.map((post: any) => {
        const date = new Date(post.published);
        const formattedDate = date.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });

        return `
          <a href="${post.url}" class="block p-4 rounded-lg border border-neutral-200 dark:border-neutral-800 hover:border-(--primary) hover:bg-neutral-50 dark:hover:bg-neutral-900/50 transition-all duration-200 group">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 group-hover:text-(--primary) transition-colors truncate">
                    ${post.title}
                  </h3>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-(--primary) shrink-0 opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24">
                    <path fill="currentColor" d="M5 13h11.17l-4.88 4.88c-.39.39-.39 1.03 0 1.42.39.39 1.02.39 1.41 0l6.59-6.59a.996.996 0 0 0 0-1.41l-6.58-6.6a.996.996 0 1 0-1.41 1.41L16.17 11H5c-.55 0-1 .45-1 1s.45 1 1 1z"/>
                  </svg>
                </div>
                ${post.description ? `
                  <p class="text-sm text-neutral-600 dark:text-neutral-400 line-clamp-2 mb-2">
                    ${post.description}
                  </p>
                ` : ''}
                <div class="flex items-center gap-3 text-xs text-neutral-500 dark:text-neutral-500">
                  <time datetime="${post.published}" class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24">
                      <path fill="currentColor" d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"/>
                    </svg>
                    ${formattedDate}
                  </time>
                  ${post.category ? `
                    <span class="flex items-center gap-1">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24">
                        <path fill="currentColor" d="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"/>
                      </svg>
                      ${post.category}
                    </span>
                  ` : ''}
                </div>
              </div>
            </div>
          </a>
        `;
      }).join('');
    }
  });
</script>
